<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Property"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginBottom="20dp"/>

        <!-- Image preview -->
        <ImageView
            android:id="@+id/ivPropertyImage"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@color/divider"
            android:scaleType="centerCrop"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btnSelectImage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📷  Select Image"
            android:textAllCaps="false"
            android:backgroundTint="@color/primary"
            android:textColor="@color/white"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"
            app:cornerRadius="10dp"/>

        <!-- Basic fields -->
        <EditText
            android:id="@+id/etTitle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Property Title *"
            android:inputType="text"
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_input_field"
            android:textColor="@color/black"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etPrice"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Price ($) *"
            android:inputType="numberDecimal"
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_input_field"
            android:textColor="@color/black"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etLocation"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Location *"
            android:inputType="text"
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_input_field"
            android:textColor="@color/black"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etDescription"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:hint="Description"
            android:inputType="textMultiLine"
            android:gravity="top|start"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:background="@drawable/bg_input_field"
            android:textColor="@color/black"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etCategory"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Category (e.g. Residential)"
            android:inputType="text"
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_input_field"
            android:textColor="@color/black"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Property Type *"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_muted"
            android:layout_marginBottom="4dp"/>

        <Spinner
            android:id="@+id/spinnerType"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_input_field"
            android:layout_marginBottom="20dp"
            android:paddingHorizontal="12dp"/>

        <!-- Divider label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Property Details"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <EditText
                android:id="@+id/etBedrooms"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:hint="Bedrooms"
                android:inputType="number"
                android:paddingHorizontal="12dp"
                android:background="@drawable/bg_input_field"
                android:textColor="@color/black"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/etBathrooms"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:hint="Bathrooms"
                android:inputType="number"
                android:paddingHorizontal="12dp"
                android:background="@drawable/bg_input_field"
                android:textColor="@color/black"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <EditText
                android:id="@+id/etLivingRooms"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:hint="Living Rooms"
                android:inputType="number"
                android:paddingHorizontal="12dp"
                android:background="@drawable/bg_input_field"
                android:textColor="@color/black"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/etKitchen"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:hint="Kitchens"
                android:inputType="number"
                android:paddingHorizontal="12dp"
                android:background="@drawable/bg_input_field"
                android:textColor="@color/black"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <EditText
                android:id="@+id/etGarage"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:hint="Garage"
                android:inputType="number"
                android:paddingHorizontal="12dp"
                android:background="@drawable/bg_input_field"
                android:textColor="@color/black"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/etGarden"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:hint="Garden"
                android:inputType="number"
                android:paddingHorizontal="12dp"
                android:background="@drawable/bg_input_field"
                android:textColor="@color/black"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <EditText
                android:id="@+id/etLivingArea"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:hint="Area (sq ft)"
                android:inputType="number"
                android:paddingHorizontal="12dp"
                android:background="@drawable/bg_input_field"
                android:textColor="@color/black"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/etYearBuilt"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:hint="Year Built"
                android:inputType="number"
                android:paddingHorizontal="12dp"
                android:background="@drawable/bg_input_field"
                android:textColor="@color/black"/>

        </LinearLayout>

        <ProgressBar
            android:id="@+id/progress_bar_add"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:visibility="gone"
            android:indeterminateTint="@color/primary"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnSubmit"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Add Property"
            android:backgroundTint="@color/accent"
            android:textColor="@color/white"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"
            app:cornerRadius="12dp"/>

    </LinearLayout>
</ScrollView>